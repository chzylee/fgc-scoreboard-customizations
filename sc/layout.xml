<!DOCTYPE StreamControlLayout>
<layout width="800" height="420" tabbed="1">
 <tab name="Match Info">
  <label x="10" y="14" width="46" height="13">Player 1</label>
  <label x="10" y="44" width="46" height="13">Player 2</label>
  <label x="10" y="74" width="46" height="13">Round</label>
  <label x="10" y="104" width="46" height="13">Game</label>
  <lineEdit id="p1Name" x="60" y="10" width="200" height="20" dataSet="players.csv" dataField="1" />
  <lineEdit id="p1Team" x="270" y="10" width="60" height="20" dataSet="players.csv" dataField="2" master="p1Name" />
  <spinBox id="p1Score" x="340" y="9" width="42" height="25" maximum="99" />
  <label x="390" y="14" width="50" height="13">Pronouns</label>
  <lineEdit id="p1Pronouns" x="445" y="10" width="130" height="20" dataSet="players.csv" dataField="3" master="p1Name" />
  <lineEdit id="p2Name" x="60" y="40" width="200" height="20" dataSet="players.csv" dataField="1"  />
  <lineEdit id="p2Team" x="270" y="40" width="60" height="20" dataSet="players.csv" dataField="2" master="p2Name" />
  <spinBox id="p2Score" x="340" y="39" width="42" height="25" maximum="99" />
  <label x="390" y="44" width="50" height="13">Pronouns</label>
  <lineEdit id="p2Pronouns" x="445" y="40" width="130" height="20" dataSet="players.csv" dataField="3" master="p2Name" />
  <lineEdit id="round" x="60" y="70" width="160" height="20" dataSet="round.csv" dataField="1"  />
  <button type="swap" x="230" y="70" width="60" height="23" tooltip="Swap the Scores" id="swap1" swapSet1="p1Name,p1Team,p1Score,p1Pronouns" swapSet2="p2Name,p2Team,p2Score,p2Pronouns">Swap</button>
  <button type="reset" x="300" y="70" width="60" height="23" tooltip="Reset the Scores" id="reset1" reset="p1Score,p2Score">Reset</button>
  <button type="reset" x="370" y="70" width="60" height="23" tooltip="Clear Match Info" id="reset2" reset="p1Name,p1Team,p1Score,p1Pronouns,p2Name,p2Team,p2Score,p2Pronouns">Clear</button>
  <comboBox id="game" editable="1" x="60" y="100" width="100" height="20">
   <comboItem>BBCF</comboItem>
   <comboItem>BBTAG</comboItem>
   <comboItem>DBFZ</comboItem>
   <comboItem>GGXRD</comboItem>
   <comboItem>KOFXIV</comboItem>
   <comboItem>MVCI</comboItem>
   <comboItem>SFVCE</comboItem>
   <comboItem>TEKKEN7</comboItem>
   <comboItem>UMVC3</comboItem>
   <comboItem>UNICLR</comboItem>
   <comboItem>USF4</comboItem>
   <comboItem>MBAACC</comboItem>
   <comboItem>GBVSR</comboItem>
  </comboBox>
 </tab>
 <tab name="Commentary">
  <label x="10" y="14" width="46" height="13">Title 1</label>
  <label x="10" y="44" width="46" height="13">Title 2</label>
  <lineEdit id="cTitle1" x="60" y="10" width="321" height="20" />
  <lineEdit id="cTitle2" x="60" y="40" width="321" height="20" />
 </tab>
 <tab name="Misc 1">
  <label x="10" y="14" width="46" height="13">mText 1</label>
  <label x="10" y="44" width="46" height="13">mText 2</label>
  <lineEdit id="mText1" x="60" y="10" width="321" height="20" />
  <lineEdit id="mText2" x="60" y="40" width="321" height="20" />
 </tab>
 <tab name="Misc 2">
  <label x="10" y="14" width="46" height="13">mText 3</label>
  <label x="10" y="44" width="46" height="13">mText 4</label>
  <lineEdit id="mText3" x="60" y="10" width="321" height="20" />
  <lineEdit id="mText4" x="60" y="40" width="321" height="20" />
 </tab>
 <tab name="Customizations">
  <label x="10" y="14" width="95" height="13">Main Color</label>
  <label x="10" y="44" width="95" height="13">Team Text Color</label>
  <label x="10" y="74" width="95" height="13">Toggle Logo</label>
  <lineEdit id="mainColor" x="110" y="10" width="100" height="20" />
  <lineEdit id="teamColor" x="110" y="40" width="100" height="20" />
  <comboBox id="toggleLogo" x="110" y="70" width="80" height="20">
   <comboItem>Hide</comboItem>
   <comboItem>Show</comboItem>
  </comboBox>
  <label x="10" y="106" width="380" height="13">Colors: hex e.g. #3f6cbd — leave blank to use stylesheet default</label>
 </tab>
</layout>
